#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define WIN     0
#define WIN_N   1
#define MAC     2
#define MAC_N   3
#define LT      4
#define RT      5
#define FN      6
#define SYS     7
#define SPC     8
/ {
    keymap {
        compatible = "zmk,keymap";
        
        windows_UIJK {
            bindings = <
                &kp TAB     &kp Q       &kp W   &kp E   &kp R   &kp T   &kp Y   &kp J   &kp K   &kp O       &kp P       &kp FSLH        &kp BSPC
                &mo FN      &kp LCTRL   &kp A   &kp S   &kp D   &kp F   &kp G   &kp H   &kp U   &kp I       &kp L       &kp SEMICOLON   &kp APOS        
                &kp LWIN    &kp LSHIFT  &kp Z   &kp X   &kp C   &kp V   &kp B   &kp N   &kp M   &kp COMMA   &kp PERIOD  &kp RSHIFT      &kp ENTER
                &kp LGUI      &kp LALT                                    &lt LT SPACE                       &kp RCTRL   &kp RALT        &kp RCTRL
            >;
        };

        windows_normie {
            bindings = <
                &kp TAB     &kp Q       &kp W   &kp E   &kp R   &kp T   &kp Y   &kp J   &kp I   &kp O       &kp P       &kp FSLH        &kp BSPC
                &mo FN      &kp LCTRL   &kp A   &kp S   &kp D   &kp F   &kp G   &kp H   &kp J   &kp K       &kp L       &kp SEMICOLON   &kp APOS        
                &kp LWIN    &kp LSHIFT  &kp Z   &kp X   &kp C   &kp V   &kp B   &kp N   &kp M   &kp COMMA   &kp PERIOD  &kp RSHIFT      &kp ENTER
                &kp LGUI      &kp LALT                                    &lt LT SPACE                       &kp RCTRL   &kp RALT        &kp RCTRL
            >;
        };

        mac_UIJK {
            bindings = <
                &kp TAB     &kp Q       &kp W   &kp E   &kp R   &kp T   &kp Y   &kp J   &kp K   &kp O       &kp P       &kp FSLH        &kp BSPC
                &mo FN      &kp LGUI    &kp A   &kp S   &kp D   &kp F   &kp G   &kp H   &kp U   &kp I       &kp L       &kp SEMICOLON   &kp APOS        
                &kp LWIN    &kp LSHIFT  &kp Z   &kp X   &kp C   &kp V   &kp B   &kp N   &kp M   &kp COMMA   &kp PERIOD  &kp RSHIFT      &kp ENTER
                &kp LGUI      &kp LALT                                    &lt LT SPACE                       &kp RGUI    &kp RALT        &kp RCTRL
            >;
        };

        mac_normie {
            bindings = <
                &kp TAB     &kp Q       &kp W   &kp E   &kp R   &kp T   &kp Y   &kp U   &kp I   &kp O       &kp P       &kp FSLH        &kp BSPC
                &mo FN      &kp LGUI    &kp A   &kp S   &kp D   &kp F   &kp G   &kp H   &kp J   &kp K       &kp L       &kp SEMICOLON   &kp APOS        
                &kp LWIN    &kp LSHIFT  &kp Z   &kp X   &kp C   &kp V   &kp B   &kp N   &kp M   &kp COMMA   &kp PERIOD  &kp RSHIFT      &kp ENTER
                &kp LGUI      &kp LALT                                    &lt LT SPACE                       &kp RGUI    &kp RALT        &kp RCTRL
            >;
        };

        lt {
            bindings = <
                &kp ESC     &kp N5      &kp N6      &kp N7      &kp N8      &kp N9      &kp N0      &kp N1      &kp N2      &kp N3      &kp N4      &kp BSLH        &kp BSPC
                &mo SYS     &trans      &kp R       &kp C       &kp M       &kp T       &kp P       &kp LEFT    &kp DOWN    &kp UP      &kp RIGHT   &trans          &trans        
                &trans      &trans      &kp GRAVE   &kp PSCRN   &kp CAPS    &kp LBKT    &kp RBKT    &kp MINUS   &kp EQUAL   &trans      &trans      &trans          &trans
                &trans      &trans                                          &trans                                                      &trans      &trans          &trans
            >;
        };

        rt {
            bindings = <
                &kp ESC     &kp N5      &kp N6      &kp N7      &kp N8      &kp N9      &kp N0      &kp N1      &kp N2      &kp N3      &kp N4      &kp BSLH        &kp DEL
                &mo SYS     &trans      &trans      &trans      &trans      &trans      &kp P       &kp O       &kp E       &kp A       &kp N       &trans          &trans       
                &trans      &trans      &kp GRAVE   &kp PSCRN   &kp CAPS    &kp LBKT    &kp RBKT    &kp MINUS   &kp EQUAL   &trans      &trans      &trans          &trans
                &trans      &trans                                          &trans                                                      &trans      &trans          &trans
            >;
        };

       fn_layer {
            bindings = <
                &none       &kp F1      &kp F2          &kp F3          &kp F4          &kp F5          &kp F6      &kp F7      &kp F8      &kp F9          &kp F10     &kp F11         &kp F12
                &trans      &none       &kp HOME        &kp PG_DN       &kp PG_UP       &kp END         &kp C_MUTE  &kp LEFT    &kp DOWN    &kp UP          &kp RIGHT   &none           &none        
                &none       &none       &kp C_BRI_DN    &kp C_BRI_UP    &kp C_VOL_DN    &kp C_VOL_UP    &kp C_PP    &kp C_RW    &kp C_FF    &kp C_PREV      &kp C_NEXT  &none           &none
                &mo SYS     &none                                                       &none                                               &none           &none                       &mo SYS
            >;
        };

        sys_layer {
            bindings = <
                &none       &out OUT_TOG     &bt BT_DISC 0    &bt BT_DISC 1    &bt BT_DISC 2    &bt BT_DISC 3    &bt BT_DISC 4  &bt BT_CLR  &none       &none         &sys_reset  &soft_off   &bootloader     
                &none       &none            &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4   &to WIN     &to MAC     &to WIN_N     &to  MAC_N  &none       &none        
                &none       &none            &none            &none            &none            &none            &none          &none       &none       &none         &none       &none       &none
                &mo SYS     &none                                                               &none                                                   &none         &none                   &mo SYS
            >;
        };

        spc_layer {
            bindings = <
                &kp ESC     &none     &none       &none       &none       &none     &none     &none       &none       &none     &none       &none      &kp DEL
                &none       &none     &kp HOME    &kp PG_DN   &kp PG_UP   &kp END   &kp INS   &kp LEFT    &kp DOWN    &kp UP    &kp RIGHT   &none      &none
                &none       &none     &none       &none       &none       &none     &none     &none       &none       &none     &none       &none       &none
                &mo SYS     &none                                                             &none                                                   &none         &none                   &mo SYS
            >;
        };
   };
};
